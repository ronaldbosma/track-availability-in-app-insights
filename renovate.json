{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "replacements:all",
    "workarounds:all",
    "group:all"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "dotnet-sdk"
      ],
      "matchFileNames": [
        "src/logicApp/Functions/TrackAvailabilityInAppInsights.LogicApp.Functions.csproj"
      ],
      "allowedVersions": "8.*",
      "description": "Logic App custom code projects should use .NET 8."
    },
    {
      "matchPackageNames": [
        "Microsoft.Azure.Functions.Worker.Sdk",
        "Microsoft.Extensions.Logging.Abstractions",
        "Microsoft.Extensions.Logging",
        "Azure.Identity"
      ],
      "matchFileNames": [
        "src/logicApp/Functions/TrackAvailabilityInAppInsights.LogicApp.Functions.csproj"
      ],
      "enabled": false,
      "description": "Disable updates for specific packages in Logic App custom code projects, because these require specific versions to match the Logic App runtime."
    },
    {
      "matchPackageNames": [
        "Microsoft.ApplicationInsights"
      ],
      "matchFileNames": [
        "src/logicApp/Functions/TrackAvailabilityInAppInsights.LogicApp.Functions.csproj"
      ],
      "allowedVersions": "<3",
      "description": "Microsoft.ApplicationInsights 3.0.0 depends on Microsoft.Extensions.Logging(.Abstractions) version 8.0.0, which is not supported in a Logic App custom code project."
    }
  ]
}